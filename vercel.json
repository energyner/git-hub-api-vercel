{
  "version": 2,
  "name": "git-hub-api-vercel",
  "builds": [
    {
      "src": "api/*.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/_common/(.*)", "dest": "/public/_common/$1" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/api/translate", "dest": "api/translate.mjs" },
    { "src": "/api/energy-consump", "dest": "api/serv-energy-consump-app.mjs" },
    { "src": "/energy-app/(.*)", "dest": "/public/energy-consump-app/$1" },
    { "src": "/(.*)", "dest": "/public/energy-consump-app/index.html" }
  ]
}