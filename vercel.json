{
  "version": 2,
  "name": "git-hub-api-vercel",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/translate",
      "destination": "/api/translate.mjs"
    },
    {
      "source": "/api/energy-consump",
      "destination": "/api/serv-energy-consump-app.mjs"
    },
    {
      "source": "/energy-app/:path*",
      "destination": "/energy-consump-app/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/energy-consump-app/index.html"
    }
  ]
}